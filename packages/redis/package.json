{
  "name": "@agora/diagnostics-redis",
  "version": "0.1.0",
  "description": "Cross-process transport for @agora/diagnostics — relay agora:<lib>:<event> events over Redis pub/sub so onDiagnostic handlers fire across processes.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavideCarvalho/adonis-diagnostics.git",
    "directory": "packages/redis"
  },
  "author": "Davi Carvalho <davi@goflip.ai>",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./diagnostics_redis_provider": {
      "types": "./dist/providers/diagnostics_redis_provider.d.ts",
      "import": "./dist/providers/diagnostics_redis_provider.js",
      "default": "./dist/providers/diagnostics_redis_provider.js"
    },
    "./configure": {
      "types": "./dist/configure.d.ts",
      "import": "./dist/configure.js",
      "default": "./dist/configure.js"
    }
  },
  "files": ["dist/", "README.md", "CHANGELOG.md"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm run copy:stubs",
    "copy:stubs": "mkdir -p dist/stubs/config && cp stubs/config/diagnostics_redis.stub dist/stubs/config/diagnostics_redis.stub",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agora/diagnostics": "workspace:^"
  },
  "peerDependencies": {
    "@adonisjs/core": "^6.12.0",
    "@adonisjs/redis": "^9.0.0",
    "ioredis": "^5"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^7.8.0",
    "@adonisjs/core": "^6.17.0",
    "@adonisjs/redis": "^9.0.0",
    "@agora/diagnostics": "workspace:*",
    "@types/node": "^20.0.0",
    "ioredis": "^5.4.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "keywords": ["adonisjs", "adonis", "diagnostics", "redis", "pubsub", "observability", "agora"]
}
